provider=groq
model=llama-3.1-8b-instant

groq.api.key=your_groq_key
groq.base.url=https://api.groq.com/openai/v1

openai.api.key=
openai.base.url=https://api.openai.com/v1

ollama.base.url=http://localhost:11434

